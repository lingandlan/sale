# =============================================================================
# Marketplace API - Local Development Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Server
APP_ENV=debug
SERVER_PORT=8080
GIN_MODE=debug

# MySQL
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=marketplace
MYSQL_USER=marketplace
MYSQL_PASSWORD=marketplace123
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DSN=${MYSQL_USER}:${MYSQL_PASSWORD}@tcp(${MYSQL_HOST}:${MYSQL_PORT})/${MYSQL_DATABASE}?charset=utf8mb4&parseTime=True&loc=Local

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_HOURS=168

# Log
LOG_LEVEL=debug
LOG_SERVICE_NAME=marketplace-api

# MailHog (optional, for local email testing)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
