# =============================================================================
# 太积堂充值与门店管理系统 - 本地开发环境变量
# 复制此文件为 .env 并填写实际值
# =============================================================================

# Server
APP_ENV=debug
SERVER_PORT=8080
GIN_MODE=debug

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=sale_dev
MYSQL_USER=sale
MYSQL_PASSWORD=sale123
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DSN=${MYSQL_USER}:${MYSQL_PASSWORD}@tcp(${MYSQL_HOST}:${MYSQL_PORT})/${MYSQL_DATABASE}?charset=utf8mb4&parseTime=True&loc=Local

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT（生产环境必须更换！）
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE_HOURS=24
REFRESH_TOKEN_EXPIRE_HOURS=168

# Mall API（商城接口 - 生产环境通过环境变量设置真实密钥）
MALL_BASE_URL=http://localhost:3001
MALL_APP_ID=
MALL_APP_SECRET=
MALL_API_KEY=test-key
MALL_MOCK=true

# 数据库密码覆盖（生产环境使用）
DB_PASSWORD=

# Redis 密码覆盖（生产环境使用）
REDIS_PASSWORD=

# CORS 允许的来源（逗号分隔，默认 localhost 开发端口）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5175

# Log
LOG_LEVEL=debug
LOG_SERVICE_NAME=sale-backend

# MailHog (可选，用于本地邮件测试)
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
