# =============================================================================
# 太积堂充值与门店管理系统 - 环境变量配置
# =============================================================================

# -----------------------------------------------------------------------------
# MySQL 配置
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=sale_dev
MYSQL_USER=sale
MYSQL_PASSWORD=sale123
MYSQL_PORT=3306

# MySQL DSN (用于 goose 迁移)
MYSQL_DSN=sale:sale123@tcp(localhost:3306)/sale_dev?charset=utf8mb4&parseTime=True&loc=Local

# -----------------------------------------------------------------------------
# Redis 配置
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_HOST=localhost
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# JWT 配置
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRE_HOURS=24
JWT_REFRESH_EXPIRE_HOURS=168

# -----------------------------------------------------------------------------
# 服务器配置
# -----------------------------------------------------------------------------
SERVER_PORT=8080
SERVER_MODE=debug

# -----------------------------------------------------------------------------
# 日志配置
# -----------------------------------------------------------------------------
LOG_MODE=debug
LOG_LEVEL=info
LOG_SERVICE_NAME=marketplace-api

# -----------------------------------------------------------------------------
# MailHog (开发环境邮件测试)
# -----------------------------------------------------------------------------
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
