# ===================================
# 太积堂生产环境配置模板
# 复制为 .env 并填入真实值：cp .env.example .env
# ===================================

# --- JWT ---
JWT_SECRET=your-jwt-secret-here

# --- MySQL ---
MYSQL_ROOT_PASSWORD=your-mysql-root-password
MYSQL_DATABASE=sale_dev
MYSQL_USER=sale
MYSQL_PASSWORD=your-mysql-password

# --- Backend DB (cmd/migrate 也用这套) ---
DB_PASSWORD=your-mysql-password

# --- WSY 商城 API ---
MALL_APP_ID=your-mall-app-id
MALL_APP_SECRET=your-mall-app-secret
MALL_CUSTOMER_ID=your-mall-customer-id
MALL_BASE_URL=https://cloud.xingyunxuan.cn/

# --- CORS ---
# 多个域名用逗号分隔
CORS_ALLOWED_ORIGINS=http://your-domain.com,http://www.your-domain.com

# --- 端口（可选，一般不需要改） ---
# BACKEND_PORT=8080
# FRONTEND_PORT=80
