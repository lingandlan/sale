{
  "openapi": "3.0.0",
  "info": {
    "title": "太积堂充值与门店管理系统 - 用户认证模块",
    "version": "1.0.0",
    "description": "用户认证与用户管理相关接口"
  },
  "servers": [
    {
      "url": "http://localhost:8080/api/v1",
      "description": "本地开发环境"
    }
  ],
  "tags": [
    {
      "name": "auth",
      "description": "用户认证"
    },
    {
      "name": "user",
      "description": "用户信息"
    },
    {
      "name": "admin",
      "description": "管理员功能"
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["auth"],
        "summary": "用户登录",
        "description": "使用手机号和密码登录系统",
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["phone", "password"],
                "properties": {
                  "phone": {
                    "type": "string",
                    "description": "手机号（登录账号）",
                    "example": "13800000000",
                    "pattern": "^1[3-9]\\d{9}$"
                  },
                  "password": {
                    "type": "string",
                    "description": "密码",
                    "example": "admin123",
                    "minLength": 6
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "登录成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "type": "string",
                          "description": "Access Token（24小时有效）",
                          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJleHAiOjE3MDQ1NjQ4MDAsInVzZXJfaWQiOjF9.xxx"
                        },
                        "refresh_token": {
                          "type": "string",
                          "description": "Refresh Token（7天有效）",
                          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJleHAiOjE3MDUxNjk2MDAsInRva2VuX3R5cGUiOiJyZWZyZXNoIn0.xxx"
                        },
                        "expire": {
                          "type": "integer",
                          "description": "Token过期时间（秒）",
                          "example": 86400
                        },
                        "user": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "integer",
                              "example": 1
                            },
                            "phone": {
                              "type": "string",
                              "example": "13800000000"
                            },
                            "name": {
                              "type": "string",
                              "example": "超级管理员"
                            },
                            "role": {
                              "type": "string",
                              "enum": ["super_admin", "admin", "operator", "store_operator"],
                              "example": "super_admin"
                            },
                            "center_id": {
                              "type": "integer",
                              "nullable": true,
                              "example": null
                            },
                            "center_name": {
                              "type": "string",
                              "nullable": true,
                              "example": null
                            }
                          }
                        }
                      }
                    }
                  }
                },
                "examples": {
                  "success": {
                    "summary": "登录成功示例",
                    "value": {
                      "code": 200,
                      "message": "success",
                      "data": {
                        "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJleHAiOjE3MDQ1NjQ4MDAsInVzZXJfaWQiOjF9.xxx",
                        "refresh_token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJleHAiOjE3MDUxNjk2MDAsInRva2VuX3R5cGUiOiJyZWZyZXNoIn0.xxx",
                        "expire": 86400,
                        "user": {
                          "id": 1,
                          "phone": "13800000000",
                          "name": "超级管理员",
                          "role": "super_admin",
                          "center_id": null,
                          "center_name": null
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "参数错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "invalidPhone": {
                    "summary": "手机号格式错误",
                    "value": {
                      "code": 400,
                      "message": "参数错误：手机号格式不正确",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "用户名或密码错误",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "invalidCredentials": {
                    "summary": "用户名或密码错误",
                    "value": {
                      "code": 401,
                      "message": "用户名或密码错误",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "423": {
            "description": "账号被禁用",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "accountDisabled": {
                    "summary": "账号被禁用",
                    "value": {
                      "code": 423,
                      "message": "账号已被禁用，请联系管理员",
                      "data": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["auth"],
        "summary": "用户登出",
        "description": "退出登录并撤销Refresh Token",
        "operationId": "logout",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "登出成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "examples": {
                  "success": {
                    "summary": "登出成功",
                    "value": {
                      "code": 200,
                      "message": "登出成功",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": ["auth"],
        "summary": "刷新Token",
        "description": "使用Refresh Token获取新的Access Token",
        "operationId": "refreshToken",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refresh_token"],
                "properties": {
                  "refresh_token": {
                    "type": "string",
                    "description": "Refresh Token",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "刷新成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "token": {
                          "type": "string",
                          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                        },
                        "refresh_token": {
                          "type": "string",
                          "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                        },
                        "expire": {
                          "type": "integer",
                          "example": 86400
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Refresh Token无效或已过期",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "invalidToken": {
                    "summary": "Token无效",
                    "value": {
                      "code": 401,
                      "message": "Refresh Token无效或已过期",
                      "data": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/user/info": {
      "get": {
        "tags": ["user"],
        "summary": "获取当前用户信息",
        "description": "获取当前登录用户的详细信息",
        "operationId": "getUserInfo",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 1
                        },
                        "phone": {
                          "type": "string",
                          "example": "13800000000"
                        },
                        "name": {
                          "type": "string",
                          "example": "超级管理员"
                        },
                        "role": {
                          "type": "string",
                          "example": "super_admin"
                        },
                        "center_id": {
                          "type": "integer",
                          "nullable": true,
                          "example": null
                        },
                        "center_name": {
                          "type": "string",
                          "nullable": true,
                          "example": null
                        },
                        "status": {
                          "type": "integer",
                          "example": 1
                        },
                        "last_login_at": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2026-04-10T10:30:00Z"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/info": {
      "put": {
        "tags": ["user"],
        "summary": "更新用户信息",
        "description": "更新当前登录用户的信息",
        "operationId": "updateUserInfo",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "姓名",
                    "example": "张三",
                    "maxLength": 50
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "更新成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                }
              }
            }
          },
          "401": {
            "description": "未授权",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/user/change-password": {
      "post": {
        "tags": ["user"],
        "summary": "修改密码",
        "description": "修改当前用户的密码",
        "operationId": "changePassword",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["old_password", "new_password"],
                "properties": {
                  "old_password": {
                    "type": "string",
                    "description": "原密码",
                    "example": "admin123"
                  },
                  "new_password": {
                    "type": "string",
                    "description": "新密码（至少6位）",
                    "example": "newpass123",
                    "minLength": 6
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "修改成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "examples": {
                  "success": {
                    "summary": "修改成功",
                    "value": {
                      "code": 200,
                      "message": "密码修改成功",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "原密码错误或新密码格式不正确",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "examples": {
                  "wrongPassword": {
                    "summary": "原密码错误",
                    "value": {
                      "code": 400,
                      "message": "原密码错误",
                      "data": null
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/users": {
      "get": {
        "tags": ["admin"],
        "summary": "获取用户列表",
        "description": "管理员获取用户列表（分页）",
        "operationId": "listUsers",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "页码",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "page_size",
            "in": "query",
            "description": "每页数量",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 10,
              "minimum": 1,
              "maximum": 100
            }
          },
          {
            "name": "phone",
            "in": "query",
            "description": "手机号搜索",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "role",
            "in": "query",
            "description": "角色筛选",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["super_admin", "admin", "operator", "store_operator"]
            }
          },
          {
            "name": "status",
            "in": "query",
            "description": "状态筛选（1=启用，0=禁用）",
            "required": false,
            "schema": {
              "type": "integer",
              "enum": [0, 1]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "获取成功",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": {
                      "type": "integer",
                      "example": 200
                    },
                    "message": {
                      "type": "string",
                      "example": "success"
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "list": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "integer"
                              },
                              "phone": {
                                "type": "string"
                              },
                              "name": {
                                "type": "string"
                              },
                              "role": {
                                "type": "string"
                              },
                              "center_id": {
                                "type": "integer",
                                "nullable": true
                              },
                              "center_name": {
                                "type": "string",
                                "nullable": true
                              },
                              "status": {
                                "type": "integer"
                              },
                              "last_login_at": {
                                "type": "string",
                                "format": "date-time"
                              },
                              "created_at": {
                                "type": "string",
                                "format": "date-time"
                              }
                            }
                          }
                        },
                        "total": {
                          "type": "integer",
                          "example": 100
                        },
                        "page": {
                          "type": "integer",
                          "example": 1
                        },
                        "page_size": {
                          "type": "integer",
                          "example": 10
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "权限不足",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/users/{id}/reset-password": {
      "post": {
        "tags": ["admin"],
        "summary": "重置用户密码",
        "description": "管理员重置指定用户的密码",
        "operationId": "resetUserPassword",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "用户ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["new_password"],
                "properties": {
                  "new_password": {
                    "type": "string",
                    "description": "新密码（默认为123456）",
                    "example": "123456"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "重置成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "examples": {
                  "success": {
                    "summary": "重置成功",
                    "value": {
                      "code": 200,
                      "message": "密码重置成功",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "权限不足",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "用户不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/users/{id}/status": {
      "put": {
        "tags": ["admin"],
        "summary": "启用/禁用用户",
        "description": "管理员启用或禁用指定用户",
        "operationId": "setUserStatus",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "用户ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {
                    "type": "integer",
                    "description": "用户状态（1=启用，0=禁用）",
                    "enum": [0, 1],
                    "example": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "设置成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "examples": {
                  "success": {
                    "summary": "启用成功",
                    "value": {
                      "code": 200,
                      "message": "用户已启用",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "权限不足",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "用户不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/admin/users/{id}": {
      "delete": {
        "tags": ["admin"],
        "summary": "删除用户",
        "description": "管理员删除指定用户（软删除）",
        "operationId": "deleteUser",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "用户ID",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "删除成功",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SuccessResponse"
                },
                "examples": {
                  "success": {
                    "summary": "删除成功",
                    "value": {
                      "code": 200,
                      "message": "用户删除成功",
                      "data": null
                    }
                  }
                }
              }
            }
          },
          "403": {
            "description": "权限不足",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "用户不存在",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT认证，格式：Bearer {token}"
      }
    },
    "schemas": {
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "响应码",
            "example": 200
          },
          "message": {
            "type": "string",
            "description": "响应消息",
            "example": "success"
          },
          "data": {
            "type": "object",
            "nullable": true
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "description": "错误码",
